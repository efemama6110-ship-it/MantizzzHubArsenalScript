-- Core Frame Rendering Loop
RunService.RenderStepped:Connect(function()
    if speedToggleEnabled and LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("Humanoid") then
        LocalPlayer.Character.Humanoid.WalkSpeed = walkSpeedValue
    end
    
    if isFlying and bodyVelocity and bodyGyro then
        local camCF = Camera.CFrame
        bodyGyro.cframe = camCF
        local moveDir = Vector3.new(flyCtrl.L + flyCtrl.R, 0, flyCtrl.F + flyCtrl.B)
        if moveDir.Magnitude > 0 then
            bodyVelocity.velocity = (camCF.RightVector * (flyCtrl.L + flyCtrl.R) + camCF.LookVector * (flyCtrl.F + flyCtrl.B)) * flySpeed
        else
            bodyVelocity.velocity = Vector3.new(0, 0, 0)
        end
    end

    FOVCircle.Radius = fovRadiusValue
    FOVCircle.Position = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)
    FOVCircle.Visible = fovCheckEnabled and aimbotEnabled

    if aimbotEnabled and rightClickHeld then
        local target = getPlayerClosestToCrosshair()
        if target then
            local targetPartName = headshotEnabled and "Head" or "HumanoidRootPart"
            local aimPart = target:FindFirstChild(targetPartName)
            if aimPart then
                local targetCFrame = CFrame.lookAt(Camera.CFrame.Position, aimPart.Position)
                Camera.CFrame = Camera.CFrame:Lerp(targetCFrame, 1 / smoothnessValue)
            end
        end
    end
    
    for _, player in pairs(Players:GetPlayers()) do
        if player ~= LocalPlayer then
            local char = player.Character
            local esp = getESP(player)
            
            local isAlive = char and char:FindFirstChild("HumanoidRootPart") and char:FindFirstChild("Head") and char:FindFirstChild("Humanoid") and char.Humanoid.Health > 0
            local isEnemy = not teamCheckEnabled or isOpponent(player)
            
            if isAlive and isEnemy then
                local rootPart = char.HumanoidRootPart
                local head = char.Head
                local humanoid = char.Humanoid
                
                local hl = char:FindFirstChild("ESP_Highlight")
                if espOutlineEnabled then
                    if not hl then
                        hl = Instance.new("Highlight")
                        hl.Name = "ESP_Highlight"
                        hl.FillTransparency = 1 
                        hl.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop 
                        hl.OutlineColor = Color3.fromRGB(255, 0, 0)
                        hl.Parent = char
                    end
                    hl.Enabled = true
                else
                    if hl then hl.Enabled = false end
                end
                
                local bottomPos, onScreenBottom = Camera:WorldToViewportPoint(rootPart.Position - Vector3.new(0, 3, 0))
                local topPos, onScreenTop = Camera:WorldToViewportPoint(head.Position + Vector3.new(0, 1, 0))
                local centerPos, onScreenCenter = Camera:WorldToViewportPoint(rootPart.Position)
                
                if onScreenTop or onScreenBottom then
                    local boxHeight = math.abs(bottomPos.Y - topPos.Y)
                    local boxWidth = boxHeight * 0.6
                    
                    if espBoxEnabled then
                        esp.Box.Size = Vector2.new(boxWidth, boxHeight)
                        esp.Box.Position = Vector2.new(topPos.X - boxWidth/2, topPos.Y)
                        esp.Box.Visible = true
                    else
                        esp.Box.Visible = false
                    end
                    
                    if espNameEnabled then
                        esp.Name.Text = player.Name
                        esp.Name.Position = Vector2.new(topPos.X, topPos.Y - 18)
                        esp.Name.Visible = true
                    else
                        esp.Name.Visible = false
                    end
                    
                    if espDistanceEnabled and LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart") then
                        local distance = math.floor((LocalPlayer.Character.HumanoidRootPart.Position - rootPart.Position).Magnitude)
                        esp.Distance.Text = tostring(distance) .. " studs"
                        esp.Distance.Position = Vector2.new(topPos.X, bottomPos.Y + 4)
                        esp.Distance.Visible = true
                    else
                        esp.Distance.Visible = false
                    end
                    
                    if espTracersEnabled and onScreenCenter then
                        esp.Tracer.From = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y)
                        esp.Tracer.To = Vector2.new(centerPos.X, centerPos.Y)
                        esp.Tracer.Visible = true
                    else
                        esp.Tracer.Visible = false
                    end
                    
                    if espHealthEnabled then
                        local hpFactor = math.clamp(humanoid.Health / humanoid.MaxHealth, 0, 1)
                        local barWidth = 3
                        local barXOffset = topPos.X - (boxWidth / 2) - barWidth - 4
                        
                        local barColor = Color3.fromRGB(0, 255, 0)
                        if hpFactor <= 0.20 then
                            barColor = Color3.fromRGB(255, 0, 0)
                        elseif hpFactor <= 0.55 then
                            barColor = Color3.fromRGB(255, 140, 0)
                        end
                        
                        esp.HealthBarBG.Size = Vector2.new(barWidth, boxHeight)
                        esp.HealthBarBG.Position = Vector2.new(barXOffset, topPos.Y)
                        esp.HealthBarBG.Visible = true
                        
                        local currentHpHeight = boxHeight * hpFactor
                        esp.HealthBar.Color = barColor
                        esp.HealthBar.Size = Vector2.new(barWidth, currentHpHeight)
                        esp.HealthBar.Position = Vector2.new(barXOffset, topPos.Y + (boxHeight - currentHpHeight))
                        esp.HealthBar.Visible = true
                    else
                        esp.HealthBarBG.Visible = false
                        esp.HealthBar.Visible = false
                    end
                    
                    if espSkeletonEnabled then
                        local tPart = char:FindFirstChild("Torso") or char:FindFirstChild("UpperTorso")
                        local lArm = char:FindFirstChild("Left Arm") or char:FindFirstChild("LeftUpperArm")
                        local rArm = char:FindFirstChild("Right Arm") or char:FindFirstChild("RightUpperArm")
                        local lLeg = char:FindFirstChild("Left Leg") or char:FindFirstChild("LeftUpperLeg")
                        local rLeg = char:FindFirstChild("Right Leg") or char:FindFirstChild("RightUpperLeg")
                        
                        if tPart and lArm and rArm and lLeg and rLeg then
                            local h2d = Camera:WorldToViewportPoint(head.Position)
                            local t2d = Camera:WorldToViewportPoint(tPart.Position)
                            local la2d = Camera:WorldToViewportPoint(lArm.Position)
                            local ra2d = Camera:WorldToViewportPoint(rArm.Position)
                            local ll2d = Camera:WorldToViewportPoint(lLeg.Position)
                            local rl2d = Camera:WorldToViewportPoint(rLeg.Position)
                            
                            esp.H2T.From = Vector2.new(h2d.X, h2d.Y) esp.H2T.To = Vector2.new(t2d.X, t2d.Y)
                            esp.T2L.From = Vector2.new(t2d.X, t2d.Y) esp.T2L.To = Vector2.new(la2d.X, la2d.Y)
                            esp.T2R.From = Vector2.new(t2d.X, t2d.Y) esp.T2R.To = Vector2.new(ra2d.X, ra2d.Y)
                            esp.T2LL.From = Vector2.new(t2d.X, t2d.Y) esp.T2LL.To = Vector2.new(ll2d.X, ll2d.Y)
                            esp.T2RL.From = Vector2.new(t2d.X, t2d.Y) esp.T2RL.To = Vector2.new(rl2d.X, rl2d.Y)
                            
                            local skelLines = {esp.H2T, esp.T2L, esp.T2R, esp.T2LL, esp.T2RL}
                            for _, l in pairs(skelLines) do l.Visible = true end
                        end
                    else
                        local skelLines = {esp.H2T, esp.T2L, esp.T2R, esp.T2LL, esp.T2RL}
                        for _, l in pairs(skelLines) do l.Visible = false end
                    end
                else
                    for _, obj in pairs(esp) do if typeof(obj) == "userdata" then obj.Visible = false end end
                end
            else
                if char then local ohl = char:FindFirstChild("ESP_Highlight") if ohl then ohl.Enabled = false end end
                for _, obj in pairs(esp) do if typeof(obj) == "userdata" then obj.Visible = false end end
            end
        end
    end
end)
