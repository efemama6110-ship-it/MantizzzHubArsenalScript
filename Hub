-- ESP Drawing Cache
local espCache = {}

local function getESP(player)
    if not espCache[player] then
        espCache[player] = {
            Box = Drawing.new("Square"),
            Name = Drawing.new("Text"),
            HealthBarBG = Drawing.new("Square"),
            HealthBar = Drawing.new("Square"),
            Distance = Drawing.new("Text"),
            Tracer = Drawing.new("Line"),
            H2T = Drawing.new("Line"), 
            T2L = Drawing.new("Line"), 
            T2R = Drawing.new("Line"), 
            T2LL = Drawing.new("Line"), 
            T2RL = Drawing.new("Line")  
        }
        
        espCache[player].Box.Color = Color3.fromRGB(255, 0, 0)
        espCache[player].Box.Thickness = 1.5
        espCache[player].Box.Filled = false
        
        local texts = {espCache[player].Name, espCache[player].Distance}
        for _, txt in pairs(texts) do
            txt.Color = Color3.fromRGB(255, 255, 255)
            txt.Size = 13
            txt.Center = true
            txt.Outline = true
            txt.Font = 2
        end
        
        espCache[player].Tracer.Color = Color3.fromRGB(255, 0, 0)
        espCache[player].Tracer.Thickness = 1
        
        espCache[player].HealthBarBG.Color = Color3.fromRGB(0, 0, 0)
        espCache[player].HealthBarBG.Filled = true
        espCache[player].HealthBarBG.Thickness = 1
        espCache[player].HealthBar.Filled = true
        espCache[player].HealthBar.Thickness = 1
        
        local skelLines = {espCache[player].H2T, espCache[player].T2L, espCache[player].T2R, espCache[player].T2LL, espCache[player].T2RL}
        for _, line in pairs(skelLines) do
            line.Color = Color3.fromRGB(255, 255, 255)
            line.Thickness = 1.5
        end
    end
    return espCache[player]
end

local function cleanPlayerESP(player)
    if espCache[player] then
        for _, obj in pairs(espCache[player]) do 
            obj:Remove() 
        end
        espCache[player] = nil
    end
end
Players.PlayerRemoving:Connect(cleanPlayerESP)

-- Strict opponent verification matrix
local function isOpponent(player)
    if player == LocalPlayer then return false end
    if teamCheckEnabled and player.Team and LocalPlayer.Team then
        if player.Team == LocalPlayer.Team and player.Team.Name ~= "FFA" then
            return false
        end
    end
    return true
end

