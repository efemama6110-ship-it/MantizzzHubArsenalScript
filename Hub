end)

-- FIXED HBE LOOP: Now checks for liveness before modifying
task.spawn(function()
    while task.wait(0.1) do
        for _, player in pairs(Players:GetPlayers()) do
            local char = player.Character
            if player ~= LocalPlayer and char then
                local head = char:FindFirstChild("Head")
                local hum = char:FindFirstChild("Humanoid")
                
                -- Critical Fix: Only apply HBE if the player is actually alive
                if hbeEnabled and isOpponent(player) and hum and hum.Health > 0 then
                    if head then
                        head.Size = Vector3.new(hbeSizeValue, hbeSizeValue, hbeSizeValue)
                        head.CanCollide = false
                        head.Transparency = hbeVisibleEnabled and 0.5 or 1
                        head.Material = Enum.Material.ForceField
                    end
                else
                    -- Reset to default immediately upon death
                    if head then
                        head.Size = Vector3.new(1.2, 1.2, 1.2)
                        head.Transparency = 0
                        head.Material = Enum.Material.Plastic
                    end
                end
            end
        end
    end
end)

