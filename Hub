-- Fly Start/Stop Functions
local function startFly()
    local char = LocalPlayer.Character
    if not char or not char:FindFirstChild("HumanoidRootPart") then return end
    
    local hrp = char.HumanoidRootPart
    bodyGyro = Instance.new("BodyGyro", hrp)
    bodyGyro.P = 9e4
    bodyGyro.maxTorque = Vector3.new(9e9, 9e9, 9e9)
    bodyGyro.cframe = hrp.CFrame
    
    bodyVelocity = Instance.new("BodyVelocity", hrp)
    bodyVelocity.velocity = Vector3.new(0, 0, 0)
    bodyVelocity.maxForce = Vector3.new(9e9, 9e9, 9e9)
    
    isFlying = true
end

local function stopFly()
    isFlying = false
    if bodyGyro then bodyGyro:Destroy() end
    if bodyVelocity then bodyVelocity:Destroy() end
end

-- If player dies, reset fly to prevent bugs
LocalPlayer.CharacterAdded:Connect(function()
    if isFlying then stopFly() end
end)

-- Input Manager for Aimbot, Fly Toggle, and Fly Movement
UserInputService.InputBegan:Connect(function(input, gameProcessed)
    if not gameProcessed then
        if input.UserInputType == Enum.UserInputType.MouseButton2 then
            rightClickHeld = true
        end
        
        if input.KeyCode == Enum.KeyCode.X and flyToggleEnabled then
            if isFlying then stopFly() else startFly() end
        end
        
        -- Fly directional controls
        if input.KeyCode == Enum.KeyCode.W then flyCtrl.F = 1 end
        if input.KeyCode == Enum.KeyCode.S then flyCtrl.B = -1 end
        if input.KeyCode == Enum.KeyCode.A then flyCtrl.L = -1 end
        if input.KeyCode == Enum.KeyCode.D then flyCtrl.R = 1 end
    end
end)

UserInputService.InputEnded:Connect(function(input, gameProcessed)
    if input.UserInputType == Enum.UserInputType.MouseButton2 then
        rightClickHeld = false
    end
    
    if input.KeyCode == Enum.KeyCode.W then flyCtrl.F = 0 end
    if input.KeyCode == Enum.KeyCode.S then flyCtrl.B = 0 end
    if input.KeyCode == Enum.KeyCode.A then flyCtrl.L = 0 end
    if input.KeyCode == Enum.KeyCode.D then flyCtrl.R = 0 end
end)

-- Crosshair Target Selection
local function getPlayerClosestToCrosshair()
    local nearestCharacter = nil
    local shortestScreenDistance = math.huge
    
    if not LocalPlayer.Character or not LocalPlayer.Character:FindFirstChild("HumanoidRootPart") then return nil end
    local screenCenter = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)

    for _, player in pairs(Players:GetPlayers()) do
        if player ~= LocalPlayer and player.Character then
            if teamCheckEnabled and player.Team == LocalPlayer.Team then continue end
            
            local character = player.Character
            local targetPartName = headshotEnabled and "Head" or "HumanoidRootPart"
            local targetPart = character:FindFirstChild(targetPartName)
            local humanoid = character:FindFirstChild("Humanoid")
            
            if targetPart and humanoid and humanoid.Health > 0 then
                local screenPos, onScreen = Camera:WorldToViewportPoint(targetPart.Position)
                if onScreen then
                    local screenDistance = (Vector2.new(screenPos.X, screenPos.Y) - screenCenter).Magnitude
                    if fovCheckEnabled then
                        if screenDistance <= fovRadiusValue and screenDistance < shortestScreenDistance then
                            shortestScreenDistance = screenDistance
                            nearestCharacter = character
                        end
                    else
                        if screenDistance < shortestScreenDistance then
                            shortestScreenDistance = screenDistance
                            nearestCharacter = character
                        end
                    end
                end
            end
        end
    end
    return nearestCharacter
end

-- Render Stepped Loop (Heartbeat of the script)
RunService.RenderStepped:Connect(function()
    
    -- 1. Enforce WalkSpeed
    if speedToggleEnabled and LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("Humanoid") then
        LocalPlayer.Character.Humanoid.WalkSpeed = walkSpeedValue
    end
    
    -- 2. Handle Fly Physics
    if isFlying and bodyVelocity and bodyGyro then
        local camCF = Camera.CFrame
        bodyGyro.cframe = camCF
        
        local moveDir = Vector3.new(flyCtrl.L + flyCtrl.R, 0, flyCtrl.F + flyCtrl.B)
        
        if moveDir.Magnitude > 0 then
            bodyVelocity.velocity = (camCF.RightVector * (flyCtrl.L + flyCtrl.R) + camCF.LookVector * (flyCtrl.F + flyCtrl.B)) * flySpeed
        else
            bodyVelocity.velocity = Vector3.new(0, 0, 0)
        end
    end

    -- 3. Manage FOV Visuals
    FOVCircle.Radius = fovRadiusValue
    FOVCircle.Position = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)
    FOVCircle.Visible = fovCheckEnabled and aimbotEnabled

    -- 4. Manage Aimbot Tracking
    if aimbotEnabled and rightClickHeld then
        local target = getPlayerClosestToCrosshair()
        if target then
            local targetPartName = headshotEnabled and "Head" or "HumanoidRootPart"
            local aimPart = target:FindFirstChild(targetPartName)
            if aimPart then
                local targetCFrame = CFrame.lookAt(Camera.CFrame.Position, aimPart.Position)
                local lerpFactor = 1 / smoothnessValue
                Camera.CFrame = Camera.CFrame:Lerp(targetCFrame, lerpFactor)
            end
        end
    end
    
    -- 5. Manage All ESP Updates
    for _, player in pairs(Players:GetPlayers()) do
        if player ~= LocalPlayer then
            local char = player.Character
            local esp = getESP(player)
            
            local isAlive = char and char:FindFirstChild("HumanoidRootPart") and char:FindFirstChild("Head") and char:FindFirstChild("Humanoid") and char.Humanoid.Health > 0
            local isEnemy = not teamCheckEnabled or (teamCheckEnabled and player.Team ~= LocalPlayer.Team)
            
            if isAlive and isEnemy then
                local rootPart = char.HumanoidRootPart
                local head = char.Head
                local humanoid = char.Humanoid
                
                -- OUTLINE ESP
                local hl = char:FindFirstChild("ESP_Highlight")
                if espOutlineEnabled then
                    if not hl then
                        hl = Instance.new("Highlight")
                        hl.Name = "ESP_Highlight"
                        hl.FillTransparency = 1 
                        hl.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop 
                        hl.OutlineColor = Color3.fromRGB(255, 0, 0)
                        hl.Parent = char
                    end
                    hl.Enabled = true
                else
                    if hl then hl.Enabled = false end
                end
                
                -- DRAWING API ESP
                local bottomPos, onScreenBottom = Camera:WorldToViewportPoint(rootPart.Position - Vector3.new(0, 3, 0))
                local topPos, onScreenTop = Camera:WorldToViewportPoint(head.Position + Vector3.new(0, 1, 0))
                
                if onScreenTop or onScreenBottom then
                    local boxHeight = math.abs(bottomPos.Y - topPos.Y)
                    local boxWidth = boxHeight * 0.6
                    
                    -- Box ESP
                    if espBoxEnabled then
                        esp.Box.Size = Vector2.new(boxWidth, boxHeight)
                        esp.Box.Position = Vector2.new(topPos.X - boxWidth/2, topPos.Y)
                        esp.Box.Visible = true
                    else
                        esp.Box.Visible = false
                    end
                    
                    -- Name ESP
                    if espNameEnabled then
                        esp.Name.Text = player.Name
                        esp.Name.Position = Vector2.new(topPos.X, topPos.Y - 18)
                        esp.Name.Visible = true
                    else
                        esp.Name.Visible = false
                    end
                    
                    -- Health Bar ESP
                    if espHealthEnabled then
                        local hpFactor = math.clamp(humanoid.Health / humanoid.MaxHealth, 0, 1)
                        local barWidth = 3
                        local barXOffset = topPos.X - (boxWidth / 2) - barWidth - 4
                        
                        -- Background (Black)
                        esp.HealthBarBG.Size = Vector2.new(barWidth, boxHeight)
                        esp.HealthBarBG.Position = Vector2.new(barXOffset, topPos.Y)
                        esp.HealthBarBG.Visible = true
                        
                        -- Foreground (Fading color)
                        local currentHpHeight = boxHeight * hpFactor
                        esp.HealthBar.Color = Color3.fromRGB(255 - (hpFactor * 255), hpFactor * 255, 0)
                        esp.HealthBar.Size = Vector2.new(barWidth, currentHpHeight)
                        esp.HealthBar.Position = Vector2.new(barXOffset, topPos.Y + (boxHeight - currentHpHeight))
                        esp.HealthBar.Visible = true
                    else
                        esp.HealthBarBG.Visible = false
                        esp.HealthBar.Visible = false
                    end
                else
                    esp.Box.Visible = false
                    esp.Name.Visible = false
                    esp.HealthBarBG.Visible = false
                    esp.HealthBar.Visible = false
                end
            else
                if char then
                    local hl = char:FindFirstChild("ESP_Highlight")
                    if hl then hl.Enabled = false end
                end
                esp.Box.Visible = false
                esp.Name.Visible = false
                esp.HealthBarBG.Visible = false
                esp.HealthBar.Visible = false
            end
        end
    end
end)
